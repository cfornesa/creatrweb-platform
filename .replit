modules = ["nodejs-24", "postgresql-16"]
run = "npm run dev"

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["npm", "run", "start"]
build = ["npm", "run", "build"]

[workflows]

[agent]
expertMode = true
integrations = ["github:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 90000

